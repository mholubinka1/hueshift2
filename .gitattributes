# Normalize all text files to LF in the repo, CRLF in the working tree
* text=auto eol=crlf

# Shell scripts must stay LF — CRLF breaks shebang execution on Linux/macOS
.githooks/* text eol=lf
*.sh text eol=lf

# Explicitly mark binary files to prevent line-ending conversion
*.png binary
*.jpg binary
*.ico binary
*.dll binary
*.exe binary
